{
  "$schema": "https://json.schemastore.org/prettierrc",
  "printWidth": 100,
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "none",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "proseWrap": "preserve",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.code-workspace"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": ["*.md", "*.yml", "*.yaml"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    }
  ]
}
